pipeline {
    agent any
    
    stages {
        stage('Checkout') {
            steps {
                // Descarga el código
                checkout scm
            }
        }
        
        stage('Build Image') {
            steps {
                script {
                    // Construye la imagen usando el Docker de la instancia EC2
                    sh "docker build -t tu-usuario-dockerhub/Act3-Dev:latest ."
                }
            }
        }
        
        stage('Push to Docker Hub') {
            steps {
                script {
                    // Login y subida (opcional pero recomendado)
                    withCredentials([usernamePassword(credentialsId: 'dockerhub-creds', passwordVariable: 'PASS', usernameVariable: 'USER')]) {
                        sh "echo $PASS | docker login -u $USER --password-stdin"
                        sh "docker push $USER/Act3-Dev:latest"
                    }
                }
            }
        }

        stage('Deploy to Prod') {
            steps {
                // Aquí usamos el SSH Agent para entrar a la otra EC2 y actualizar
                sshagent(['prod-server-key']) {
                    sh "ssh -o StrictHostKeyChecking=no ec2-user@IP_PRIVADA_PROD 'docker pull tu-usuario/Act3-Dev:latest && docker run -d -p 5000:5000 tu-usuario/Act3-Dev:latest'"
                }
            }
        }
    }
}